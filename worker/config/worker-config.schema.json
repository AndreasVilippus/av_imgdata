{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-imgdata.local/schemas/worker-config.schema.json",
  "title": "AV ImgData external worker configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "worker_id",
    "worker_api_base_url",
    "auth",
    "workspace_root",
    "path_base_dir",
    "input_modes",
    "processors",
    "poll_interval_seconds"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "worker_id": {"type": "string", "minLength": 1},
    "worker_api_base_url": {"type": "string", "minLength": 1},
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "token_file"],
      "properties": {
        "type": {"const": "worker_token"},
        "token_file": {"type": "string", "minLength": 1}
      }
    },
    "workspace_root": {"type": "string", "minLength": 1},
    "path_base_dir": {"type": "string", "minLength": 1},
    "input_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["shared_path"]}
    },
    "processors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["face", "image_vips"],
      "properties": {
        "face": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "model_root", "model_name"],
          "properties": {
            "path": {"type": "string", "minLength": 1},
            "model_root": {"type": "string", "minLength": 1},
            "model_name": {"type": "string", "minLength": 1}
          }
        },
        "image_vips": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "path"],
          "properties": {
            "enabled": {"type": "boolean"},
            "path": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "poll_interval_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "max_parallel_jobs": {"type": "integer", "minimum": 1, "maximum": 64},
    "log_level": {"enum": ["debug", "info", "warning", "error"]}
  }
}
