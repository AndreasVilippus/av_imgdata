#!/bin/sh

PACKAGE="AV_ImgData"
VAR_DIR="${SYNOPKG_PKGVAR:-/var/packages/${PACKAGE}/var}"
PID_FILE="${VAR_DIR}/${PACKAGE}.pid"
LOG_FILE="${VAR_DIR}/server.log"
VENV_DIR="${SYNOPKG_PKGDEST}/var/venv"
PYTHON="${VENV_DIR}/bin/python"
PIP="${VENV_DIR}/bin/pip"
UVICORN="${VENV_DIR}/bin/uvicorn"
CORE_REQS="${SYNOPKG_PKGDEST}/src/requirements.txt"
OPTIONAL_REQS_DIR="${SYNOPKG_PKGDEST}/src"
WHEEL_DIR="${SYNOPKG_PKGDEST}/wheels"
DOWNLOADED_WHEEL_DIR="${VAR_DIR}/wheelhouse"
CONFIG_FILE="${VAR_DIR}/config.json"
PIP_STATUS_FILE="${VAR_DIR}/pip_packages_status.json"
PIP_TMP_DIR="${VAR_DIR}/pip_tmp"
PIP_CACHE_DIR="${VAR_DIR}/pip_cache"
APP_MODULE="app.main:app"
HOST="127.0.0.1"
PORT="9771"

export NO_ALBUMENTATIONS_UPDATE=1

is_running() {
    [ -f "${PID_FILE}" ] || return 1
    pid="$(cat "${PID_FILE}" 2>/dev/null)"
    [ -n "${pid}" ] || return 1
    kill -0 "${pid}" 2>/dev/null
}

log() {
    echo "[$(date '+%F %T')] $*" >> "${LOG_FILE}"
}

pip_install_requirements() {
    req_file="$1"
    wheel_dir="${2:-${WHEEL_DIR}}"
    [ -f "${req_file}" ] || return 1
    mkdir -p "${PIP_TMP_DIR}" "${PIP_CACHE_DIR}" 2>/dev/null

    if [ -d "${wheel_dir}" ] && ls "${wheel_dir}"/*.whl >/dev/null 2>&1; then
        TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PIP}" install --no-index --find-links "${wheel_dir}" -r "${req_file}" >> "${LOG_FILE}" 2>&1
        return $?
    fi

    TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PIP}" install -r "${req_file}" >> "${LOG_FILE}" 2>&1
}

pip_install_requirements_with_capture() {
    req_file="$1"
    output_file="$2"
    wheel_dir="${3:-${WHEEL_DIR}}"
    [ -f "${req_file}" ] || return 1
    mkdir -p "${PIP_TMP_DIR}" "${PIP_CACHE_DIR}" "$(dirname "${output_file}")" 2>/dev/null

    if [ -d "${wheel_dir}" ] && ls "${wheel_dir}"/*.whl >/dev/null 2>&1; then
        TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PIP}" install --only-binary=:all: --no-index --find-links "${wheel_dir}" -r "${req_file}" > "${output_file}" 2>&1
        result=$?
    else
        TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PIP}" install --only-binary=:all: -r "${req_file}" > "${output_file}" 2>&1
        result=$?
    fi
    cat "${output_file}" >> "${LOG_FILE}" 2>/dev/null
    return "${result}"
}

pip_install_wheelhouse_manifest_with_capture() {
    manifest_path="$1"
    output_file="$2"
    [ -f "${manifest_path}" ] || return 1
    mkdir -p "${PIP_TMP_DIR}" "${PIP_CACHE_DIR}" "$(dirname "${output_file}")" 2>/dev/null

    TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PYTHON}" - "${PIP}" "${manifest_path}" > "${output_file}" 2>&1 <<'PY'
import json
import subprocess
import sys
from pathlib import Path

pip_path = sys.argv[1]
manifest_path = Path(sys.argv[2])
manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
packages = manifest.get("packages")
if not isinstance(packages, list) or not packages:
    raise RuntimeError("wheelhouse manifest does not contain packages")

wheel_paths = []
for package in packages:
    if not isinstance(package, dict):
        raise RuntimeError("wheelhouse manifest package entry is invalid")
    filename = str(package.get("file") or "").strip()
    if not filename:
        raise RuntimeError("wheelhouse manifest package entry misses file")
    wheel_path = manifest_path.parent / filename
    if not wheel_path.is_file():
        raise RuntimeError(f"wheelhouse asset missing: {wheel_path}")
    wheel_paths.append(str(wheel_path))

command = [pip_path, "install", "--only-binary=:all:", "--no-index", *wheel_paths]
raise SystemExit(subprocess.call(command))
PY
    result=$?
    cat "${output_file}" >> "${LOG_FILE}" 2>/dev/null
    return "${result}"
}

prepare_optional_python_package_install() {
    package_key="$1"
    [ -x "${PIP}" ] || return 0

    case "${package_key}" in
        INSIGHTFACE)
            # OpenCV distributions share the same cv2 module. Remove stale or GUI
            # variants first so the pinned headless wheel from requirements wins.
            TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PIP}" uninstall -y \
                opencv-python \
                opencv-contrib-python \
                opencv-python-headless \
                opencv-contrib-python-headless \
                >> "${LOG_FILE}" 2>&1 || true
            ;;
    esac
}

finalize_optional_python_package_install() {
    package_key="$1"
    [ -x "${PIP}" ] || return 0

    case "${package_key}" in
        INSIGHTFACE)
            TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PIP}" uninstall -y \
                opencv-python \
                opencv-contrib-python \
                opencv-contrib-python-headless \
                >> "${LOG_FILE}" 2>&1 || true
            TMPDIR="${PIP_TMP_DIR}" PIP_CACHE_DIR="${PIP_CACHE_DIR}" "${PIP}" install \
                --only-binary=:all: \
                --force-reinstall \
                --no-deps \
                opencv-python-headless==4.10.0.84 \
                >> "${LOG_FILE}" 2>&1
            ;;
    esac
}

validate_optional_python_package_install() {
    package_key="$1"
    [ -x "${PYTHON}" ] || return 0

    case "${package_key}" in
        INSIGHTFACE)
            "${PYTHON}" -c '
import importlib
for module_name in ("cv2", "onnxruntime", "insightface.app"):
    importlib.import_module(module_name)
' >> "${LOG_FILE}" 2>&1
            ;;
        *)
            return 0
            ;;
    esac
}

ensure_core_python_packages() {
    if [ ! -x "${PYTHON}" ] || [ ! -x "${PIP}" ]; then
        log "python venv is missing or incomplete at ${VENV_DIR}"
        return 1
    fi

    if "${PYTHON}" -c "import fastapi, uvicorn, requests" >> "${LOG_FILE}" 2>&1; then
        return 0
    fi

    log "core python packages missing; trying to install ${CORE_REQS}"
    if ! pip_install_requirements "${CORE_REQS}"; then
        log "core requirements install failed"
        return 1
    fi

    if ! "${PYTHON}" -c "import fastapi, uvicorn, requests" >> "${LOG_FILE}" 2>&1; then
        log "core python package validation failed after install"
        return 1
    fi

    return 0
}

enabled_optional_requirement_files() {
    [ -x "${PYTHON}" ] || return 0
    [ -f "${CONFIG_FILE}" ] || return 0
    "${PYTHON}" -c '
import json
import sys
from pathlib import Path

config_path = Path(sys.argv[1])
try:
    config = json.loads(config_path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

packages = config.get("pip_packages") if isinstance(config, dict) else {}
if not isinstance(packages, dict):
    sys.exit(0)

allowed = {"INSIGHTFACE": "requirements-optional-insightface.txt"}
for key, default_file in allowed.items():
    package_config = packages.get(key)
    if not isinstance(package_config, dict):
        continue
    if not bool(package_config.get("ENABLED")) or not bool(package_config.get("INSTALL_ON_START", True)):
        continue
    req_file = str(package_config.get("REQUIREMENTS_FILE") or default_file).strip()
    wheelhouse_enabled = "1" if bool(package_config.get("WHEELHOUSE_ENABLED")) else "0"
    wheelhouse_manifest_url = str(package_config.get("WHEELHOUSE_MANIFEST_URL") or "").strip()
    wheelhouse_target = str(package_config.get("WHEELHOUSE_TARGET") or "").strip()
    if req_file and "/" not in req_file and "\\" not in req_file:
        print(f"{key}|{req_file}|{wheelhouse_enabled}|{wheelhouse_manifest_url}|{wheelhouse_target}")
' "${CONFIG_FILE}"
}

prepare_optional_python_wheelhouse() {
    package_key="$1"
    manifest_url="$2"
    target="$3"
    requirements_file="$4"
    target_dir="$5"

    [ -n "${manifest_url}" ] || return 1
    [ -n "${target}" ] || return 1
    [ -n "${requirements_file}" ] || return 1
    mkdir -p "${target_dir}" 2>/dev/null || return 1

    "${PYTHON}" - "${manifest_url}" "${target}" "${requirements_file}" "${target_dir}" >> "${LOG_FILE}" 2>&1 <<'PY'
import hashlib
import json
import os
import sys
import urllib.request
from pathlib import Path
from urllib.parse import urlsplit


def sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


manifest_url = sys.argv[1]
expected_target = sys.argv[2]
expected_requirements = sys.argv[3]
target_dir = Path(sys.argv[4])
target_dir.mkdir(parents=True, exist_ok=True)
for existing_wheel in target_dir.glob("*.whl"):
    existing_wheel.unlink()
manifest_path = target_dir / "wheelhouse-manifest.json"

with urllib.request.urlopen(manifest_url) as response:
    manifest_bytes = response.read()
manifest_path.write_bytes(manifest_bytes)
manifest = json.loads(manifest_bytes.decode("utf-8"))
if not isinstance(manifest, dict):
    raise RuntimeError("wheelhouse manifest is not a JSON object")
if str(manifest.get("target") or "").strip() != expected_target:
    raise RuntimeError(f"wheelhouse manifest target mismatch: expected {expected_target}")
if str(manifest.get("requirements_file") or "").strip() != expected_requirements:
    raise RuntimeError(f"wheelhouse manifest requirements mismatch: expected {expected_requirements}")

packages = manifest.get("packages")
if not isinstance(packages, list) or not packages:
    raise RuntimeError("wheelhouse manifest does not contain packages")

base_url = manifest_url.rsplit("/", 1)[0].rstrip("/")
for package in packages:
    if not isinstance(package, dict):
        raise RuntimeError("wheelhouse manifest package entry is invalid")
    filename = str(package.get("file") or "").strip()
    expected_hash = str(package.get("sha256") or "").strip().lower()
    if not filename or not expected_hash:
        raise RuntimeError("wheelhouse manifest package entry misses file or sha256")
    asset_url = f"{base_url}/{filename}"
    destination = target_dir / filename
    with urllib.request.urlopen(asset_url) as response:
        destination.write_bytes(response.read())
    actual_hash = sha256(destination)
    if actual_hash != expected_hash:
        raise RuntimeError(f"wheel hash mismatch for {filename}: expected {expected_hash}, got {actual_hash}")

print(f"downloaded {len(packages)} wheelhouse assets for {expected_target}")
PY
}

write_optional_pip_status() {
    package_key="$1"
    req_name="$2"
    status="$3"
    message="$4"
    "${PYTHON}" -c '
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

status_path = Path(sys.argv[1])
package_key = sys.argv[2]
requirements_file = sys.argv[3]
status = sys.argv[4]
message = sys.argv[5]

try:
    payload = json.loads(status_path.read_text(encoding="utf-8"))
except Exception:
    payload = {}
if not isinstance(payload, dict):
    payload = {}

packages = payload.get("packages")
if not isinstance(packages, dict):
    packages = {}
packages[package_key] = {
    "status": status,
    "success": status == "success",
    "requirements_file": requirements_file,
    "message": message,
    "last_attempt_at": datetime.now(timezone.utc).isoformat(),
}
payload["packages"] = packages
status_path.parent.mkdir(parents=True, exist_ok=True)
status_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True) + "\n", encoding="utf-8")
' "${PIP_STATUS_FILE}" "${package_key}" "${req_name}" "${status}" "${message}" >> "${LOG_FILE}" 2>&1
}

install_optional_python_packages() {
    enabled_optional_requirement_files | while IFS='|' read -r package_key req_name wheelhouse_enabled wheelhouse_manifest_url wheelhouse_target; do
        [ -n "${package_key}" ] || continue
        [ -n "${req_name}" ] || continue
        if [ "${wheelhouse_enabled}" != "1" ]; then
            log "optional package ${package_key} skipped: wheelhouse-only installation is required"
            write_optional_pip_status "${package_key}" "${req_name}" "failed" "wheelhouse-only installation is required for optional packages"
            continue
        fi
        package_wheel_dir="${DOWNLOADED_WHEEL_DIR}/${package_key}/${wheelhouse_target}"
        log "preparing optional wheelhouse for ${package_key} from ${wheelhouse_manifest_url}"
        if ! prepare_optional_python_wheelhouse "${package_key}" "${wheelhouse_manifest_url}" "${wheelhouse_target}" "${req_name}" "${package_wheel_dir}"; then
            install_message="wheelhouse download or verification failed; see ${LOG_FILE}"
            log "optional wheelhouse preparation failed for ${package_key}; package start continues"
            write_optional_pip_status "${package_key}" "${req_name}" "failed" "${install_message}"
            continue
        fi
        manifest_path="${package_wheel_dir}/wheelhouse-manifest.json"
        log "installing optional python packages for ${package_key} from wheelhouse manifest ${manifest_path}"
        prepare_optional_python_package_install "${package_key}"
        install_output="${VAR_DIR}/pip_install_${package_key}.log"
        pip_install_wheelhouse_manifest_with_capture "${manifest_path}" "${install_output}"
        install_result=$?
        if [ "${install_result}" -ne 0 ]; then
            install_message="$(tail -n 20 "${install_output}" 2>/dev/null | tr '\n' ' ' | cut -c 1-900)"
            [ -n "${install_message}" ] || install_message="pip install failed; see ${LOG_FILE}"
            log "optional wheelhouse install failed for ${package_key}; package start continues"
            write_optional_pip_status "${package_key}" "${req_name}" "failed" "${install_message}"
        elif ! finalize_optional_python_package_install "${package_key}"; then
            install_message="optional package finalization failed; see ${LOG_FILE}"
            log "optional requirements finalization failed for ${req_file}; package start continues"
            write_optional_pip_status "${package_key}" "${req_name}" "failed" "${install_message}"
        elif ! validate_optional_python_package_install "${package_key}"; then
            install_message="optional packages installed but runtime import validation failed; see ${LOG_FILE}"
            log "optional requirements runtime validation failed for ${req_file}; package start continues"
            write_optional_pip_status "${package_key}" "${req_name}" "failed" "${install_message}"
        else
            log "optional requirements install completed for ${req_file}"
            write_optional_pip_status "${package_key}" "${req_name}" "success" "pip install completed"
        fi
    done
}

start() {
    mkdir -p "${VAR_DIR}"
    cd "${SYNOPKG_PKGDEST}" || exit 1

    if is_running; then
        echo "${PACKAGE} already running (pid $(cat "${PID_FILE}"))."
        return 0
    fi

    echo "Starting ${PACKAGE}..."
    if ! ensure_core_python_packages; then
        echo "Failed to start ${PACKAGE}. Core Python packages are missing. See ${LOG_FILE}."
        return 1
    fi

    install_optional_python_packages

    "${UVICORN}" "${APP_MODULE}" \
        --host "${HOST}" \
        --port "${PORT}" \
        --proxy-headers \
        --forwarded-allow-ips="*" \
        >> "${LOG_FILE}" 2>&1 &
    echo $! > "${PID_FILE}"
    sleep 1

    if is_running; then
        echo "Started ${PACKAGE} (pid $(cat "${PID_FILE}"))."
        return 0
    fi

    echo "Failed to start ${PACKAGE}. See ${LOG_FILE}."
    return 1
}

stop() {
    if ! is_running; then
        echo "${PACKAGE} is not running."
        rm -f "${PID_FILE}"
        return 0
    fi

    pid="$(cat "${PID_FILE}")"
    echo "Stopping ${PACKAGE} (pid ${pid})..."
    kill "${pid}" 2>/dev/null

    i=0
    while kill -0 "${pid}" 2>/dev/null; do
        i=$((i + 1))
        if [ "${i}" -ge 10 ]; then
            kill -9 "${pid}" 2>/dev/null
            break
        fi
        sleep 1
    done

    rm -f "${PID_FILE}"
    echo "Stopped ${PACKAGE}."
    return 0
}

status() {
    if is_running; then
        echo "${PACKAGE} is running (pid $(cat "${PID_FILE}"))."
        return 0
    fi
    echo "${PACKAGE} is stopped."
    return 1
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
