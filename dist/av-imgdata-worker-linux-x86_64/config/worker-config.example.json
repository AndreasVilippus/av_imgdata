{
  "auth": {
    "token_file": "../worker.token",
    "type": "worker_token"
  },
  "dsm_base_url": "https://nas.example:5001",
  "log_level": "info",
  "max_parallel_jobs": 1,
  "poll_interval_seconds": 2,
  "processors": {
    "face": {
      "model_name": "buffalo_l",
      "model_root": "../../../.models/face",
      "path": "../bin/av-imgdata-face-processor"
    },
    "image_vips": {
      "enabled": false,
      "path": "../bin/av-imgdata-image-processor"
    }
  },
  "worker_id": "worker-01",
  "workspace_root": "../work"
}
