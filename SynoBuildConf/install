#!/bin/bash
set -e

PKG_DIR="/tmp/_AV_ImgData_pkg"
rm -rf "$PKG_DIR"
mkdir -p "$PKG_DIR"

# load helper functions
source /pkgscripts/include/pkg_util.sh

create_install() {
	local package_tgz_dir=/tmp/_install

	# clear destination directory
	rm -rf $package_tgz_dir && mkdir -p $package_tgz_dir
	make clean_python_artifacts

	# install needed file into PKG_DIR on NAS
	cp -av src $package_tgz_dir
	cp -av app $package_tgz_dir
	cp -av conf $package_tgz_dir
	find "$package_tgz_dir/app" "$package_tgz_dir/src" -type d -name '__pycache__' -prune -exec rm -rf {} +
	find "$package_tgz_dir/app" "$package_tgz_dir/src" -type f \( -name '*.pyc' -o -name '*.pyo' \) -delete
	make install DESTDIR="$package_tgz_dir" INSTALLDIR="$package_tgz_dir"
	# Fail fast if UI entrypoint didn't get packaged
	if [ ! -f "$package_tgz_dir/ui/index.cgi" ]; then
		echo "ERROR: ui/index.cgi missing in package staging dir."
		echo "Check ui/Makefile install target and build artifacts."
		exit 1
	fi
	make packageinstall DESTDIR="$package_tgz_dir" PKG_DIR="$PKG_DIR"

	# create package.tgz $1: source_dir $2: dest_dir
	pkg_make_package $package_tgz_dir "${PKG_DIR}"
}

create_spk() {
	# copy scripts, conf and optional files
	cp -av scripts $PKG_DIR/scripts
	cp -av conf $PKG_DIR
	cp -av LICENSE $PKG_DIR/LICENSE
	cp -av ui/PACKAGE_ICON.png  $PKG_DIR/PACKAGE_ICON.PNG
	cp -av ui/PACKAGE_ICON_256.png $PKG_DIR/PACKAGE_ICON_256.PNG

	./INFO.sh > INFO
	cp INFO $PKG_DIR/INFO

	# spk name functions: pkg_get_spk_name pkg_get_spk_unified_name pkg_get_spk_family_name
	mkdir -p /image/packages
	pkg_make_spk ${PKG_DIR} "/image/packages" $(pkg_get_spk_family_name)
}

main() {
	create_install
	create_spk
}

main "$@"
