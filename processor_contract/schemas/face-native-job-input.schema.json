{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-imgdata.local/schemas/face-native-job-input.schema.json",
  "title": "AV ImgData native face processor job input",
  "type": "object",
  "required": ["contract_version", "job_id", "type", "input", "options"],
  "additionalProperties": true,
  "properties": {
    "contract_version": { "const": "1.0" },
    "job_id": { "type": "string", "minLength": 1 },
    "type": {
      "enum": [
        "face_native_detect",
        "face_native_embed",
        "face_native_detect_batch",
        "face_native_embed_batch",
        "face_native_rank_embeddings",
        "face_native_profile_math"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "image_path": { "type": "string", "minLength": 1 },
        "image_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_id": { "type": "string" }
      },
      "anyOf": [
        { "required": ["image_path"] },
        { "required": ["image_paths"] },
        {}
      ]
    },
    "target_embeddings": {
      "type": "array",
      "items": { "type": "array", "items": { "type": "number" } }
    },
    "profile_embeddings": {
      "type": "array",
      "items": { "type": "array", "items": { "type": "number" } }
    },
    "embeddings": {
      "type": "array",
      "items": { "type": "array", "items": { "type": "number" } }
    },
    "options": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model_root": { "type": "string" },
        "model_name": { "type": "string" },
        "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_faces": { "type": "integer", "minimum": 0 },
        "det_size": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "normalize_coordinates": { "type": "boolean" }
      }
    }
  }
}
